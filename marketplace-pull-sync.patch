@@ -0,0 +1,65 @@
+name: Sync Marketplace
+
+on:
+  schedule:
+    - cron: '*/15 * * * *'
+  workflow_dispatch:
+    inputs:
+      source_repo:
+        description: Optional plugin repository to sync, for example leeguooooo/yapi-plugin
+        required: false
+        default: ''
+        type: string
+      force:
+        description: Force a sync even when the remote SHA matches the recorded snapshot
+        required: false
+        default: false
+        type: boolean
+
+permissions:
+  contents: write
+
+concurrency:
+  group: marketplace-sync
+  cancel-in-progress: false
+
+jobs:
+  sync:
+    runs-on: ubuntu-latest
+    steps:
+      - name: Checkout marketplace
+        uses: actions/checkout@v4
+        with:
+          fetch-depth: 0
+
+      - name: Setup Node
+        uses: actions/setup-node@v4
+        with:
+          node-version: 20
+
+      - name: Sync plugin snapshots
+        env:
+          SOURCE_REPO: ${{ inputs.source_repo || '' }}
+          FORCE_SYNC: ${{ inputs.force && 'true' || 'false' }}
+        run: |
+          if [ -n "$SOURCE_REPO" ]; then
+            node scripts/sync-plugin.mjs --repo "$SOURCE_REPO" --force "$FORCE_SYNC"
+          else
+            node scripts/sync-plugin.mjs --force "$FORCE_SYNC"
+          fi
+
+      - name: Validate marketplace
+        run: node scripts/validate-template.mjs
+
+      - name: Commit and push synced plugins
+        run: |
+          if git diff --quiet; then
+            echo "No marketplace sync changes detected."
+            exit 0
+          fi
+
+          git config user.name "github-actions[bot]"
+          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
+          git add .
+          git commit -m "chore(sync): refresh plugin snapshots"
+          git push origin HEAD:main
