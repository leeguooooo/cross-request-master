{
  "name": "@leeguoo/yapi-mcp",
  "version": "0.5.2",
  "description": "YApi CLI - Command-line tool for YApi API documentation management, search, and docs sync",
  "main": "dist/yapi-cli.js",
  "bin": {
    "yapi": "dist/bin.js",
    "yapi-cli": "dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "skill-template"
  ],
  "scripts": {
    "build": "tsc && tsc-alias",
    "type-check": "tsc --noEmit",
    "start": "node dist/yapi-cli.js",
    "dev": "cross-env NODE_ENV=development tsx watch src/yapi-cli.ts",
    "smoke:global": "pnpm build && tsx scripts/smoke-global.ts",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "node --test --import tsx tests/*.test.ts",
    "prepare": "pnpm run build && chmod +x ./dist/yapi-cli.js",
    "pub:release": "pnpm build && npm publish"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leeguooooo/cross-request-master.git"
  },
  "keywords": [
    "yapi",
    "cli",
    "typescript",
    "api-documentation",
    "ai-tools",
    "api-management",
    "yapi-integration",
    "interface-management",
    "api-design",
    "documentation-tool",
    "docs-sync"
  ],
  "author": "liangzhensheng <372959130@qq.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "agent-browser-stealth": "^0.16.1-fork.4",
    "@types/yargs": "^17.0.33",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "markdown-it": "^14.1.0",
    "remeda": "^2.20.1",
    "yargs": "^17.7.2"
  },
  "optionalDependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.17.32",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.5.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
