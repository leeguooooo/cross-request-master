+name: Sync Plugin
+
+on:
+  repository_dispatch:
+    types:
+      - plugin-updated
+  workflow_dispatch:
+    inputs:
+      source_repo:
+        description: Source plugin repository, for example leeguooooo/yapi-plugin
+        required: true
+        type: string
+      source_ref:
+        description: Branch or tag to sync
+        required: false
+        default: main
+        type: string
+      source_sha:
+        description: Optional exact commit SHA to sync
+        required: false
+        default: ''
+        type: string
+
+permissions:
+  contents: write
+
+concurrency:
+  group: sync-plugin-${{ github.event.client_payload.source_repo || inputs.source_repo || github.run_id }}
+  cancel-in-progress: false
+
+jobs:
+  sync:
+    runs-on: ubuntu-latest
+    steps:
+      - name: Checkout marketplace
+        uses: actions/checkout@v4
+        with:
+          fetch-depth: 0
+
+      - name: Setup Node
+        uses: actions/setup-node@v4
+        with:
+          node-version: 20
+
+      - name: Sync plugin snapshot
+        id: sync
+        env:
+          SOURCE_REPO: ${{ github.event.client_payload.source_repo || inputs.source_repo }}
+          SOURCE_REF: ${{ github.event.client_payload.source_ref || inputs.source_ref || 'main' }}
+          SOURCE_SHA: ${{ github.event.client_payload.source_sha || inputs.source_sha || '' }}
+        run: |
+          node scripts/sync-plugin.mjs \
+            --repo "$SOURCE_REPO" \
+            --ref "$SOURCE_REF" \
+            --sha "$SOURCE_SHA"
+
+      - name: Validate marketplace
+        run: node scripts/validate-template.mjs
+
+      - name: Commit and push synced plugin
+        env:
+          PLUGIN_DIR: ${{ steps.sync.outputs.plugin_dir }}
+          SOURCE_REPO: ${{ steps.sync.outputs.source_repo }}
+          SOURCE_REF: ${{ steps.sync.outputs.source_ref }}
+        run: |
+          if git diff --quiet; then
+            echo "No sync changes detected."
+            exit 0
+          fi
+
+          git config user.name "github-actions[bot]"
+          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
+          git add "."
+          git commit -m "chore(sync): update ${PLUGIN_DIR} from ${SOURCE_REPO}@${SOURCE_REF}"
+          git push origin HEAD:main
